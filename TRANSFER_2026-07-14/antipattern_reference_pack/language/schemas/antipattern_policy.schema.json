{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordo.dev/schemas/antipattern_policy.schema.json",
  "title": "Ordo Anti-pattern Severity and Enforcement Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_version",
    "severity_order",
    "decision_matrix"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.antipattern_policy.v1"
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "severity_order": {
      "type": "array",
      "const": [
        "info",
        "warning",
        "error",
        "critical"
      ]
    },
    "decision_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "not_matched",
        "advisory",
        "blocking"
      ],
      "properties": {
        "not_matched": {
          "const": "allow"
        },
        "advisory": {
          "const": "allow_with_advisory"
        },
        "blocking": {
          "const": "block"
        }
      }
    },
    "critical_must_block": {
      "const": true
    },
    "error_default_enforcement": {
      "enum": [
        "advisory",
        "blocking"
      ]
    },
    "warning_default_enforcement": {
      "const": "advisory"
    },
    "info_default_enforcement": {
      "const": "advisory"
    }
  }
}
