{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordo.dev/schemas/antipattern_finding.schema.json",
  "title": "Ordo ANTIPATTERN.FINDING",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_type",
    "finding_id",
    "rule_id",
    "antipattern_id",
    "matched",
    "severity",
    "enforcement",
    "decision",
    "message",
    "evidence",
    "recovery",
    "remediation",
    "source",
    "timestamps"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.antipattern_finding.v1"
    },
    "finding_type": {
      "const": "ANTIPATTERN.FINDING"
    },
    "finding_id": {
      "type": "string",
      "pattern": "^FIND-[A-Z0-9][A-Z0-9_-]{2,127}$"
    },
    "rule_id": {
      "type": "string",
      "minLength": 2
    },
    "antipattern_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{2,127}$"
    },
    "matched": {
      "type": "boolean"
    },
    "severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ]
    },
    "enforcement": {
      "enum": [
        "advisory",
        "blocking"
      ]
    },
    "decision": {
      "enum": [
        "allow",
        "allow_with_advisory",
        "block",
        "inconclusive"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 3
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signal",
          "predicate",
          "observed_value"
        ],
        "properties": {
          "signal": {
            "type": "string",
            "minLength": 2
          },
          "predicate": {
            "type": "string",
            "minLength": 2
          },
          "observed_value": {},
          "expected_value": {},
          "source_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "recovery": {
      "type": "object"
    },
    "remediation": {
      "type": "object"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_type",
        "source_id"
      ],
      "properties": {
        "context_type": {
          "enum": [
            "conversation",
            "process_trace",
            "repository_state",
            "package_state",
            "evidence_state",
            "runtime_state"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detected_at"
      ],
      "properties": {
        "detected_at": {
          "type": "string",
          "format": "date-time"
        },
        "resolved_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "open",
            "accepted",
            "remediated",
            "waived"
          ]
        },
        "note": {
          "type": "string"
        },
        "authorized_by": {
          "type": "string"
        }
      }
    }
  }
}
