{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordo.dev/schemas/antipattern_wiring_hook.schema.json",
  "title": "Ordo anti-pattern wiring hook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "hook_id",
    "phase",
    "adapter",
    "context_type",
    "source_id",
    "input",
    "output",
    "decision_policy",
    "routing"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.antipattern_wiring_hook.v1"
    },
    "hook_id": {
      "type": "string",
      "pattern": "^APH-[A-Z0-9][A-Z0-9_-]{2,127}$"
    },
    "phase": {
      "enum": [
        "before_node_execution",
        "after_state_update_before_transition",
        "before_repository_mutation",
        "before_package_finalization",
        "before_final_status_claim"
      ]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "class", "method", "activation_profile"],
      "properties": {
        "module": {"const": "language.integration.antipattern_gate_adapter"},
        "class": {"const": "AntipatternGateAdapter"},
        "method": {"const": "evaluate_gate"},
        "activation_profile": {
          "const": "language/integration/antipattern_activation_profile.apf.v1.json"
        }
      }
    },
    "context_type": {
      "enum": [
        "conversation",
        "process_trace",
        "repository_state",
        "package_state",
        "evidence_state",
        "runtime_state"
      ]
    },
    "source_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable node, transition, gate, package, evidence, or repository mutation identifier."
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_projection", "required_signals_policy"],
      "properties": {
        "state_projection": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "source_hash_ref": {"type": ["string", "null"]},
        "required_signals_policy": {
          "enum": [
            "profile_defined",
            "explicit_projection_must_cover_blocking_rules"
          ]
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_state_field",
        "findings_state_field",
        "gate_status_state_field",
        "evidence_refs_state_field"
      ],
      "properties": {
        "report_state_field": {"type": "string", "minLength": 1},
        "findings_state_field": {"type": "string", "minLength": 1},
        "gate_status_state_field": {"type": "string", "minLength": 1},
        "evidence_refs_state_field": {"type": "string", "minLength": 1}
      }
    },
    "decision_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block", "allow_with_advisory", "allow", "inconclusive"],
      "properties": {
        "block": {"const": "stop_transition_and_route_to_repair"},
        "allow_with_advisory": {"const": "continue_and_persist_findings"},
        "allow": {"const": "continue_and_persist_report"},
        "inconclusive": {
          "const": "block_when_required_signals_missing_for_blocking_rule"
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["on_block", "on_allow", "on_advisory"],
      "properties": {
        "on_block": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action", "repair_target"],
          "properties": {
            "action": {"const": "route_to_repair"},
            "repair_target": {"type": "string", "minLength": 1}
          }
        },
        "on_allow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action"],
          "properties": {"action": {"const": "continue_transition"}}
        },
        "on_advisory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action"],
          "properties": {"action": {"const": "continue_transition_with_evidence"}}
        }
      }
    },
    "enabled_antipattern_overrides": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "PROMPT_AS_IMPLEMENTATION",
          "PACKAGE_VALIDATION_WITHOUT_COMPLETENESS_VALIDATION",
          "MANDATORY_BRANCH_SHORT_CIRCUIT",
          "FINAL_LABEL_OVERCLAIM",
          "SCOPE_CONFIRMATION_AS_IMPLEMENTATION_AUTHORIZATION",
          "COMPLEXITY_ROUTING_AND_EXECUTION_IN_ONE_NODE"
        ]
      }
    }
  }
}
