{
  "schema_version": "ordo.antipattern_registry.v1",
  "registry_version": "M88.1-hierarchical-classification-1",
  "status": "active",
  "items": [
    {
      "schema_version": "ordo.antipattern_def.v1",
      "id": "PROMPT_AS_IMPLEMENTATION",
      "name": "Prompt as Implementation",
      "summary": "An implementation prompt is treated as completed code or as proof that implementation occurred.",
      "severity": "critical",
      "enforcement": "blocking",
      "scope": [
        "process",
        "repository",
        "package",
        "evidence"
      ],
      "symptoms": [
        "Implementation is declared complete while only instructions or prompts exist.",
        "Code, tests, repository patch or executable evidence are absent."
      ],
      "detection": {
        "rule_ids": [
          "AP-29"
        ],
        "required_signals": [
          "implementation_prompt_present",
          "implementation_artifacts_absent"
        ],
        "optional_signals": [
          "completion_claim_present"
        ],
        "match_mode": "all_required"
      },
      "recovery": {
        "preserve": [
          "approved_scope",
          "analysis",
          "contracts",
          "implementation_prompt"
        ],
        "invalidate": [
          "package_completeness",
          "final_confirmation",
          "completion_status"
        ],
        "resume_from": "CODE_IMPLEMENTATION"
      },
      "remediation": {
        "actions": [
          "Create the required implementation artifacts.",
          "Execute tests and produce repository-bound evidence.",
          "Re-run package completeness validation."
        ],
        "owner": "developer"
      },
      "evidence": {
        "required_artifacts": [
          "source_code",
          "tests",
          "repository_patch",
          "test_execution_log"
        ],
        "reference_ids": [
          "APF_IMPLEMENTATION_PROMPT_AS_IMPLEMENTATION_ANTIPATTERNS_UK"
        ]
      },
      "tags": [
        "implementation",
        "evidence",
        "package"
      ],
      "version": "v1",
      "status": "active",
      "classification_level": "subpattern",
      "fundamental_id": "EVIDENCE_REALITY_MISMATCH",
      "generalization_note": "This detector-level pattern is a concrete manifestation of the referenced fundamental anti-pattern and is not a separate fundamental principle."
    },
    {
      "schema_version": "ordo.antipattern_def.v1",
      "id": "PACKAGE_VALIDATION_WITHOUT_COMPLETENESS_VALIDATION",
      "name": "Package Validation Without Completeness Validation",
      "summary": "A package is structurally validated without checking whether all required implementation artifacts exist.",
      "severity": "error",
      "enforcement": "blocking",
      "scope": [
        "package",
        "evidence",
        "process"
      ],
      "symptoms": [
        "Checksums and archive structure pass while mandatory implementation artifacts are missing."
      ],
      "detection": {
        "rule_ids": [
          "AP-30"
        ],
        "required_signals": [
          "package_structure_valid",
          "mandatory_artifacts_missing"
        ],
        "match_mode": "all_required"
      },
      "recovery": {
        "preserve": [
          "valid_documents",
          "valid_checksums"
        ],
        "invalidate": [
          "package_completeness",
          "release_label"
        ],
        "resume_from": "PACKAGE_COMPLETENESS_GATE"
      },
      "remediation": {
        "actions": [
          "Compare package contents against the mandatory artifact manifest.",
          "Add missing artifacts or downgrade the package maturity label."
        ],
        "owner": "mixed"
      },
      "evidence": {
        "required_artifacts": [
          "artifact_manifest",
          "package_inventory",
          "completeness_report"
        ],
        "reference_ids": [
          "APF_IMPLEMENTATION_PROMPT_AS_IMPLEMENTATION_ANTIPATTERNS_UK"
        ]
      },
      "tags": [
        "package",
        "completeness",
        "validation"
      ],
      "version": "v1",
      "status": "active",
      "classification_level": "subpattern",
      "fundamental_id": "INCOMPLETE_VALIDATION_MODEL",
      "generalization_note": "This detector-level pattern is a concrete manifestation of the referenced fundamental anti-pattern and is not a separate fundamental principle."
    },
    {
      "schema_version": "ordo.antipattern_def.v1",
      "id": "MANDATORY_BRANCH_SHORT_CIRCUIT",
      "name": "Mandatory Branch Short Circuit",
      "summary": "A required process branch is bypassed and execution jumps directly to a later stage.",
      "severity": "critical",
      "enforcement": "blocking",
      "scope": [
        "process",
        "runtime"
      ],
      "symptoms": [
        "Packaging or finalization begins before implementation, review or test execution is complete."
      ],
      "detection": {
        "rule_ids": [
          "AP-31"
        ],
        "required_signals": [
          "required_stage_missing",
          "later_stage_entered"
        ],
        "match_mode": "all_required"
      },
      "recovery": {
        "preserve": [
          "completed_valid_stages"
        ],
        "invalidate": [
          "later_stage_outputs",
          "completion_status"
        ],
        "resume_from": "FIRST_MISSING_MANDATORY_STAGE"
      },
      "remediation": {
        "actions": [
          "Stop the later stage.",
          "Return to the first missing mandatory stage.",
          "Re-evaluate downstream gates after completion."
        ],
        "owner": "runtime"
      },
      "evidence": {
        "required_artifacts": [
          "process_trace",
          "stage_completion_map"
        ],
        "reference_ids": [
          "APF_IMPLEMENTATION_PROMPT_AS_IMPLEMENTATION_ANTIPATTERNS_UK"
        ]
      },
      "tags": [
        "process",
        "branch",
        "gate"
      ],
      "version": "v1",
      "status": "active",
      "classification_level": "subpattern",
      "fundamental_id": "CONTROL_FLOW_INTEGRITY_VIOLATION",
      "generalization_note": "This detector-level pattern is a concrete manifestation of the referenced fundamental anti-pattern and is not a separate fundamental principle."
    },
    {
      "schema_version": "ordo.antipattern_def.v1",
      "id": "FINAL_LABEL_OVERCLAIM",
      "name": "Final Label Overclaim",
      "summary": "The final status or package label claims a maturity level unsupported by available artifacts and evidence.",
      "severity": "error",
      "enforcement": "blocking",
      "scope": [
        "package",
        "evidence",
        "process"
      ],
      "symptoms": [
        "A package is labeled complete, release-ready or confirmed without sufficient implementation evidence."
      ],
      "detection": {
        "rule_ids": [
          "AP-32"
        ],
        "required_signals": [
          "final_label_present",
          "supporting_evidence_insufficient"
        ],
        "match_mode": "all_required"
      },
      "recovery": {
        "preserve": [
          "existing_artifacts"
        ],
        "invalidate": [
          "final_label",
          "completion_claim"
        ],
        "resume_from": "MATURITY_REASSESSMENT"
      },
      "remediation": {
        "actions": [
          "Downgrade the maturity label to the highest supported level.",
          "List missing evidence required for the desired label."
        ],
        "owner": "reviewer"
      },
      "evidence": {
        "required_artifacts": [
          "maturity_evidence_matrix",
          "artifact_inventory"
        ],
        "reference_ids": [
          "APF_IMPLEMENTATION_PROMPT_AS_IMPLEMENTATION_ANTIPATTERNS_UK"
        ]
      },
      "tags": [
        "label",
        "maturity",
        "evidence"
      ],
      "version": "v1",
      "status": "active",
      "classification_level": "subpattern",
      "fundamental_id": "STATUS_EVIDENCE_MISMATCH",
      "generalization_note": "This detector-level pattern is a concrete manifestation of the referenced fundamental anti-pattern and is not a separate fundamental principle."
    },
    {
      "schema_version": "ordo.antipattern_def.v1",
      "id": "SCOPE_CONFIRMATION_AS_IMPLEMENTATION_AUTHORIZATION",
      "name": "Scope Confirmation as Implementation Authorization",
      "summary": "Confirmation of change scope is incorrectly interpreted as authorization to mutate repository state.",
      "severity": "critical",
      "enforcement": "blocking",
      "scope": [
        "conversation",
        "process",
        "repository"
      ],
      "symptoms": [
        "Repository mutation starts immediately after the user confirms scope."
      ],
      "detection": {
        "rule_ids": [
          "SCOPE-NOT-AUTHORIZATION-01",
          "REPOSITORY-MUTATION-AUTHORIZATION-01"
        ],
        "required_signals": [
          "scope_confirmed",
          "repository_mutation_started",
          "mutation_authorization_absent"
        ],
        "match_mode": "all_required"
      },
      "recovery": {
        "preserve": [
          "confirmed_scope"
        ],
        "invalidate": [
          "implicit_mutation_authorization"
        ],
        "resume_from": "CHANGE_COMPLEXITY_ASSESSMENT",
        "special_route": "UNAUTHORIZED_MUTATION_REVIEW"
      },
      "remediation": {
        "actions": [
          "Stop repository mutation.",
          "Assess change complexity.",
          "Select an execution route.",
          "Obtain explicit repository mutation authorization."
        ],
        "owner": "mixed"
      },
      "evidence": {
        "required_artifacts": [
          "scope_confirmation",
          "authorization_record",
          "repository_diff"
        ],
        "reference_ids": [
          "APF_SCOPE_CONFIRMATION_EXECUTION_ROUTING_ANTIPATTERNS_UK"
        ]
      },
      "tags": [
        "scope",
        "authorization",
        "repository"
      ],
      "version": "v1",
      "status": "active",
      "classification_level": "subpattern",
      "fundamental_id": "AUTHORIZATION_BOUNDARY_VIOLATION",
      "generalization_note": "This detector-level pattern is a concrete manifestation of the referenced fundamental anti-pattern and is not a separate fundamental principle."
    },
    {
      "schema_version": "ordo.antipattern_def.v1",
      "id": "COMPLEXITY_ROUTING_AND_EXECUTION_IN_ONE_NODE",
      "name": "Complexity Routing and Execution in One Node",
      "summary": "A single node assesses complexity, selects a route, obtains authorization and starts execution.",
      "severity": "error",
      "enforcement": "blocking",
      "scope": [
        "conversation",
        "process",
        "runtime"
      ],
      "symptoms": [
        "One response confirms several semantically independent decisions.",
        "Assessment and repository mutation occur in the same process node."
      ],
      "detection": {
        "rule_ids": [
          "COMPLEXITY-ASSESSMENT-REQUIRED-01",
          "EXECUTION-ROUTE-SELECTION-01",
          "NO-IMPLEMENTATION-BEFORE-ROUTE-01"
        ],
        "required_signals": [
          "single_node_multi_decision",
          "execution_started"
        ],
        "optional_signals": [
          "route_not_explicit",
          "authorization_not_explicit"
        ],
        "match_mode": "all_required"
      },
      "recovery": {
        "preserve": [
          "scope",
          "analysis_inputs"
        ],
        "invalidate": [
          "combined_decision",
          "implicit_authorization"
        ],
        "resume_from": "CHANGE_COMPLEXITY_ASSESSMENT"
      },
      "remediation": {
        "actions": [
          "Split assessment, route selection and authorization into separate nodes.",
          "Require explicit transition before execution."
        ],
        "owner": "runtime"
      },
      "evidence": {
        "required_artifacts": [
          "process_trace",
          "node_decision_log"
        ],
        "reference_ids": [
          "APF_SCOPE_CONFIRMATION_EXECUTION_ROUTING_ANTIPATTERNS_UK"
        ]
      },
      "tags": [
        "routing",
        "authorization",
        "single-responsibility"
      ],
      "version": "v1",
      "status": "active",
      "classification_level": "subpattern",
      "fundamental_id": "RESPONSIBILITY_CONFLATION",
      "generalization_note": "This detector-level pattern is a concrete manifestation of the referenced fundamental anti-pattern and is not a separate fundamental principle."
    }
  ]
}
