{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "ordo.empirical_evidence.scorecard.v1",
  "type": "object",
  "required": [
    "schema_version",
    "scorecard_id",
    "run_id",
    "method_version",
    "dimensions",
    "composite_score",
    "source_run_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.empirical_evidence.scorecard.v1"
    },
    "scorecard_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "method_version": {
      "type": "string"
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "composite_score": {
      "type": "number"
    },
    "source_run_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "status": {
      "enum": [
        "derived",
        "admitted",
        "superseded"
      ]
    }
  }
}
