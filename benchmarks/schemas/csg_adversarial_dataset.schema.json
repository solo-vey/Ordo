{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordo.dev/schemas/csg_adversarial_dataset.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_version",
    "taxonomy_version",
    "case_count",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.csg.adversarial_dataset.v2"
    },
    "dataset_version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "taxonomy_version": {
      "type": "string",
      "minLength": 1
    },
    "case_count": {
      "type": "integer",
      "minimum": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "title",
          "category",
          "input",
          "candidate",
          "expected"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "pattern": "^CSG-ADV-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "input": {
            "type": "object"
          },
          "candidate": {
            "type": "object"
          },
          "expected": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "semantic_match",
              "mismatch_class"
            ],
            "properties": {
              "semantic_match": {
                "type": "boolean"
              },
              "mismatch_class": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
