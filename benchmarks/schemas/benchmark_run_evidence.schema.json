{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordo.dev/schemas/benchmark_run_evidence.schema.json",
  "title": "Ordo Benchmark Run Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "run_id",
    "benchmark_mode",
    "dataset_version",
    "protocol_version",
    "provider",
    "model",
    "invocation",
    "artifacts",
    "result",
    "timestamps"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.benchmark_run_evidence.v1"
    },
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_mode": {
      "enum": [
        "fixture",
        "replay",
        "real-model"
      ]
    },
    "dataset_version": {
      "type": "string",
      "minLength": 1
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "api_family"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "api_family": {
          "type": "string",
          "minLength": 1
        },
        "endpoint_class": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_id",
        "resolved_id"
      ],
      "properties": {
        "requested_id": {
          "type": "string",
          "minLength": 1
        },
        "resolved_id": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt",
        "temperature",
        "top_p",
        "max_output_tokens",
        "seed",
        "timeout_seconds"
      ],
      "properties": {
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "temperature": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "top_p": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "max_output_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "seed": {
          "type": [
            "integer",
            "null"
          ]
        },
        "timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "retry_of_run_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_sha256",
        "input_sha256",
        "raw_output_sha256",
        "normalized_output_sha256"
      ],
      "properties": {
        "prompt_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "raw_output_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "normalized_output_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "prompt_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "input_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "raw_output_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "normalized_output_path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "score",
        "matched",
        "mismatched",
        "alias_matches",
        "error"
      ],
      "properties": {
        "status": {
          "enum": [
            "passed",
            "failed",
            "error",
            "blocked"
          ]
        },
        "score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "matched": {
          "type": "integer",
          "minimum": 0
        },
        "mismatched": {
          "type": "integer",
          "minimum": 0
        },
        "alias_matches": {
          "type": "integer",
          "minimum": 0
        },
        "mismatch_classes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "error": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "type",
            "message",
            "retryable"
          ],
          "properties": {
            "type": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "retryable": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_at",
        "finished_at"
      ],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "git_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "build_session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_tree_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
