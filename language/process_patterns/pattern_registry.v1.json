{"schema_version":"ordo.process_pattern_registry.v1","governance":{"promotion":"candidate -> validated -> stable","recommendation_policy":"fail_closed","minimum_real_packages":2,"human_approval_required":true},"patterns":[{"id":"PAT-GUIDED-REVIEW-LOOP","name":"Guided review and correction loop","status":"stable","intent":"Collect structured input, validate it, expose defects, and repeat until an explicit acceptance gate passes.","applicability":{"requires":["structured_state","validation_gate","bounded_retry"],"excludes":["irreversible_action_before_acceptance"]},"steps":[{"id":"collect","action":"collect or derive candidate state"},{"id":"validate","action":"run deterministic validation"},{"id":"review","action":"present defects and required corrections"},{"id":"accept","action":"exit only through explicit acceptance gate"}],"composition":{"may_follow":["PAT-SHARED-CONVERGENCE"],"max_nesting":2,"conflict_policy":"explicit_gate_wins"},"evidence_requirements":["validation report","decision log","accepted-state snapshot"],"review_template":{"sections":["Context","Evidence","Defects","Decision","Follow-up"],"decision_values":["accept","revise","reject"]},"provenance":{"packages":["history_event_guided_intake","ordo_applied_project_factory"]}},{"id":"PAT-SHARED-CONVERGENCE","name":"Shared convergence tail","status":"stable","intent":"Route multiple valid branches into one deterministic validation and completion tail without duplicating policy.","applicability":{"requires":["multiple_predecessors","equivalent_completion_semantics","deterministic_return"],"excludes":["branch_specific_side_effects"]},"steps":[{"id":"normalize","action":"normalize branch outputs"},{"id":"converge","action":"enter shared tail"},{"id":"validate","action":"apply common validation and completion policy"}],"composition":{"may_precede":["PAT-GUIDED-REVIEW-LOOP"],"max_nesting":4,"conflict_policy":"protected_state_wins"},"evidence_requirements":["semantic equivalence report","state projection contr