{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordo.dev/schemas/antipattern_def.schema.json",
  "title": "Ordo ANTIPATTERN.DEF",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "summary",
    "severity",
    "enforcement",
    "scope",
    "symptoms",
    "detection",
    "recovery",
    "remediation",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.antipattern_def.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{2,127}$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ]
    },
    "enforcement": {
      "enum": [
        "advisory",
        "blocking"
      ]
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "language",
          "runtime",
          "apf",
          "process",
          "repository",
          "package",
          "evidence",
          "conversation"
        ]
      }
    },
    "symptoms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_ids",
        "required_signals",
        "match_mode"
      ],
      "properties": {
        "rule_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9][A-Z0-9_-]{2,127}$"
          }
        },
        "required_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "optional_signals": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "match_mode": {
          "enum": [
            "all_required",
            "any_required",
            "threshold"
          ]
        },
        "threshold": {
          "type": "integer",
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "match_mode": {
                "const": "threshold"
              }
            },
            "required": [
              "match_mode"
            ]
          },
          "then": {
            "required": [
              "threshold"
            ]
          }
        }
      ]
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserve",
        "invalidate",
        "resume_from"
      ],
      "properties": {
        "preserve": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "invalidate": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resume_from": {
          "type": "string",
          "minLength": 2
        },
        "special_route": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actions"
      ],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5
          }
        },
        "owner": {
          "enum": [
            "model",
            "runtime",
            "developer",
            "reviewer",
            "user",
            "mixed"
          ]
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_artifacts",
        "reference_ids"
      ],
      "properties": {
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "reference_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
      }
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "classification_level": {
      "enum": [
        "fundamental",
        "subpattern",
        "detector_case"
      ]
    },
    "fundamental_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{2,127}$"
    },
    "generalization_note": {
      "type": "string",
      "minLength": 10
    }
  }
}
