{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordo.dev/schemas/detect_rule.schema.json",
  "title": "Ordo DETECT.RULE",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "antipattern_id",
    "name",
    "description",
    "input_contract",
    "condition",
    "output_contract",
    "evaluation"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.detect_rule.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9_-]{2,127}$"
    },
    "antipattern_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{2,127}$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "input_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_schema_version",
        "required_signals"
      ],
      "properties": {
        "signal_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "required_signals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{1,127}$"
          }
        },
        "optional_signals": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{1,127}$"
          }
        },
        "allowed_contexts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "conversation",
              "process_trace",
              "repository_state",
              "package_state",
              "evidence_state",
              "runtime_state"
            ]
          }
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator",
        "clauses"
      ],
      "properties": {
        "operator": {
          "enum": [
            "all",
            "any",
            "threshold"
          ]
        },
        "clauses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "signal",
              "predicate"
            ],
            "properties": {
              "signal": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]{1,127}$"
              },
              "predicate": {
                "enum": [
                  "is_true",
                  "is_false",
                  "exists",
                  "missing",
                  "equals",
                  "not_equals",
                  "contains",
                  "not_contains",
                  "greater_than",
                  "less_than"
                ]
              },
              "value": {}
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "predicate": {
                      "enum": [
                        "equals",
                        "not_equals",
                        "contains",
                        "not_contains",
                        "greater_than",
                        "less_than"
                      ]
                    }
                  },
                  "required": [
                    "predicate"
                  ]
                },
                "then": {
                  "required": [
                    "value"
                  ]
                }
              }
            ]
          }
        },
        "threshold": {
          "type": "integer",
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "operator": {
                "const": "threshold"
              }
            },
            "required": [
              "operator"
            ]
          },
          "then": {
            "required": [
              "threshold"
            ]
          }
        }
      ]
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_type",
        "include_evidence",
        "include_recovery",
        "include_remediation"
      ],
      "properties": {
        "finding_type": {
          "const": "ANTIPATTERN.FINDING"
        },
        "include_evidence": {
          "type": "boolean"
        },
        "include_recovery": {
          "type": "boolean"
        },
        "include_remediation": {
          "type": "boolean"
        },
        "finding_code": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_-]{2,127}$"
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "missing_signal_policy",
        "deterministic"
      ],
      "properties": {
        "mode": {
          "enum": [
            "static",
            "runtime",
            "hybrid"
          ]
        },
        "missing_signal_policy": {
          "enum": [
            "no_match",
            "inconclusive",
            "error"
          ]
        },
        "deterministic": {
          "type": "boolean"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        }
      }
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
      }
    }
  }
}
