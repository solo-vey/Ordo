{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"benchmark.run_acceptance_record.v1",
  "type":"object",
  "required":["schema_version","run_id","variant","playbook_version","revision","status","artifact_audited","integrity_status","scores","confirmed_by_user","history"],
  "properties":{
    "schema_version":{"const":"benchmark.run_acceptance_record.v1"},
    "run_id":{"enum":["RUN_01","RUN_02","RUN_03","RUN_04","RUN_05"]},
    "variant":{"enum":["yaml_playbook","structured_instructions","mixed_accumulated_instructions","domain_adapted_all_in_one"]},
    "playbook_version":{"type":"string","minLength":1},
    "revision":{"type":"integer","minimum":1},
    "status":{"enum":["RECEIVED_NOT_CONFIRMED","AUDITED_AWAITING_CONFIRMATION","CONFIRMED","REJECTED","QUARANTINED","SUPERSEDED"]},
    "artifact_audited":{"type":"boolean"},
    "integrity_status":{"enum":["PASS","FAIL","UNRESOLVED","NOT_APPLICABLE"]},
    "result_sha256":{"type":["string","null"],"pattern":"^[0-9a-f]{64}$"},
    "audit_sha256":{"type":["string","null"],"pattern":"^[0-9a-f]{64}$"},
    "scores":{"type":"object","required":["process_quality","document_quality","final_quality"],"properties":{"process_quality":{"type":"integer","minimum":0,"maximum":100},"document_quality":{"type":"integer","minimum":0,"maximum":100},"final_quality":{"type":"integer","minimum":0,"maximum":100}},"additionalProperties":false},
    "confirmed_by_user":{"type":"boolean"},
    "confirmation_evidence":{"type":["string","null"]},
    "supersedes_revision":{"type":["integer","null"],"minimum":1},
    "history":{"type":"array","items":{"type":"object","required":["event","timestamp"],"properties":{"event":{"type":"string"},"timestamp":{"type":"string"},"note":{"type":"string"}},"additionalProperties":true}}
  },
  "additionalProperties":true
}
