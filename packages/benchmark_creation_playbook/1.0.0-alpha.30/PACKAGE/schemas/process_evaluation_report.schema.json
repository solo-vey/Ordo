{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ordo.benchmark.process_evaluation_report.schema.json",
  "title": "Process Evaluation Report",
  "type": "object",
  "required": [
    "schema_version",
    "attempt_id",
    "run_id",
    "process_quality_contract_version",
    "dimensions",
    "raw_process_score",
    "detected_failures",
    "final_process_score",
    "blind_status",
    "evidence_references",
    "evaluator"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.benchmark.process_evaluation_report.v1"
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN_[0-9]{2,}$"
    },
    "package_variant": {
      "type": "string"
    },
    "process_quality_contract_version": {
      "type": "string"
    },
    "failure_cap_registry_version": {
      "type": "string"
    },
    "evaluation_status": {
      "enum": [
        "draft",
        "complete",
        "blocked",
        "invalid-evidence"
      ]
    },
    "dimensions": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "id",
          "weight",
          "normalized_result",
          "score",
          "criteria"
        ],
        "properties": {
          "id": {
            "pattern": "^PQ-[0-9]{2}$"
          },
          "weight": {
            "type": "number",
            "minimum": 0
          },
          "normalized_result": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          },
          "score": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 100
          },
          "criteria": {
            "type": "array"
          }
        }
      }
    },
    "raw_process_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "detected_failures": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "applied_cap": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "final_process_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "blind_status": {
      "enum": [
        "clean",
        "contaminated",
        "unknown"
      ]
    },
    "evidence_references": {
      "type": "array"
    },
    "uncertainty": {
      "type": "array"
    },
    "evaluator": {
      "type": "object",
      "required": [
        "id",
        "evaluated_at"
      ]
    }
  }
}
