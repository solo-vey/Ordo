{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ordo.benchmark.package_variant_manifest.v1",
  "type": "object",
  "required": [
    "schema_version",
    "variant"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.benchmark.package_variant_manifest.v1"
    },
    "variant": {
      "type": "object",
      "required": [
        "id",
        "version",
        "source_revision",
        "source_sha256",
        "compiler_profile",
        "supported_runs",
        "driver_family",
        "contamination_declaration",
        "files",
        "readiness"
      ],
      "properties": {
        "id": {
          "enum": [
            "PV-YAML",
            "PV-STRUCTURED",
            "PV-HISTORICAL",
            "PV-DIRECT"
          ]
        },
        "version": {
          "type": "string"
        },
        "source_revision": {
          "type": "string"
        },
        "source_sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "compiler_profile": {
          "type": "object",
          "required": [
            "id",
            "version"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "supported_runs": {
          "type": "array",
          "items": {
            "pattern": "^RUN_[0-9]{2,}$"
          },
          "minItems": 1
        },
        "driver_family": {
          "enum": [
            "step_bound",
            "semantic_adaptive",
            "pending_driver_selection"
          ]
        },
        "contamination_declaration": {
          "type": "object",
          "required": [
            "status",
            "checked_sources",
            "findings"
          ],
          "properties": {
            "status": {
              "enum": [
                "clean",
                "finding",
                "blocked"
              ]
            },
            "checked_sources": {
              "type": "array"
            },
            "findings": {
              "type": "array"
            }
          },
          "additionalProperties": false
        },
        "files": {
          "type": "array"
        },
        "readiness": {
          "enum": [
            "draft",
            "variant_ready",
            "blocked"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}