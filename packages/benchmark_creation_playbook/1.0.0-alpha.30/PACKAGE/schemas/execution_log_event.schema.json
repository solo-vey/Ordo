{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Log Event",
  "type": "object",
  "required": [
    "schema_version",
    "attempt_id",
    "sequence",
    "timestamp",
    "event_type",
    "actor",
    "visibility_class",
    "correlation_id",
    "payload",
    "previous_event_hash",
    "event_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "ordo.benchmark.execution_event.v1"
    },
    "attempt_id": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "actor": {
      "enum": [
        "launcher",
        "driver",
        "executor",
        "terminal_gate",
        "system"
      ]
    },
    "visibility_class": {
      "enum": [
        "executor-visible",
        "driver-private",
        "evaluator-only",
        "shared-evidence"
      ]
    },
    "correlation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "previous_event_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_hash": {
      "type": "string"
    }
  },
  "additionalProperties": false
}