{
  "schema_version": "ordo.benchmark.evaluation_methodology.v1",
  "methodology_id": "ORDO-BENCH-EVAL",
  "version": "1.0.0",
  "status": "canonical",
  "scores": {
    "process_quality": {
      "range": [
        0,
        100
      ]
    },
    "document_quality": {
      "range": [
        0,
        100
      ]
    },
    "final_quality": {
      "formula": "round((process_quality + document_quality) / 2)",
      "range": [
        0,
        100
      ]
    }
  },
  "mandatory_principles": [
    "evidence_first",
    "external_rules_are_authoritative",
    "validator_pass_is_not_sufficient",
    "no_fabricated_inputs",
    "historical_scores_are_immutable"
  ],
  "default_documents": [
    {
      "id": "passport",
      "weight": 0.25
    },
    {
      "id": "jira",
      "weight": 0.25
    },
    {
      "id": "manual_qa",
      "weight": 0.25
    },
    {
      "id": "automation",
      "weight": 0.25
    }
  ],
  "allowed_profile_changes": [
    "artifact_selection",
    "artifact_weights",
    "expected_terminal_states",
    "scenario_specific_checks",
    "stricter_caps",
    "authoritative_fact_bindings"
  ],
  "forbidden_profile_changes": [
    "remove_evidence_first",
    "change_three_score_model",
    "allow_unbound_scores",
    "weaken_integrity",
    "validator_pass_implies_full_score"
  ],
  "binding_fields": [
    "methodology_version",
    "methodology_sha256",
    "profile_version",
    "profile_sha256",
    "effective_methodology_sha256"
  ]
}
